# Template for ".env". Copy this file to ".env" and fill in real values.
#   - ".env"          is git-ignored (holds real local secrets)
#   - ".env.example"  is committed (documents which keys are required)

# --- Postgres (docker-compose) ---
POSTGRES_USER=aqb
POSTGRES_PASSWORD=change_me
POSTGRES_DB=aqb

# --- Backend (required from stage 1 onward) ---
# DATABASE_URL password MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgresql+asyncpg://aqb:change_me@localhost:5432/aqb
# JWT signing secret. Generate a real one with:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=replace_me_with_a_random_secret

# --- Stage 6: AI integration (optional) ---
# Leave BOTH keys blank to run without AI: stages 0-5 work unchanged and
# every /ai endpoint just returns 503 "AI not configured".
#
# Text tasks (tag suggestion / knowledge summary / question generation).
# Get one at https://platform.deepseek.com/ .
DEEPSEEK_API_KEY=
# Vision task (parse-question: split unlabeled options + recover LaTeX).
# Put a Google Gemini API key here (https://aistudio.google.com/apikey).
VISION_API_KEY=
# Optional overrides (defaults are sensible — leave unset normally):
#   DEEPSEEK_MODEL=deepseek-chat
#   VISION_MODEL=gemini-2.5-flash-lite   # 2.0-flash is retired for new keys
#   AI_DAILY_TOKEN_LIMIT=200000
#   AI_RATE_LIMIT_PER_MIN=20
#   AI_MAX_TOKENS=1024
