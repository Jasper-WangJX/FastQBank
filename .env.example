# Template for ".env". Copy this file to ".env" and fill in real values.
#   - ".env"          is git-ignored (holds real local secrets)
#   - ".env.example"  is committed (documents which keys are required)

# --- Postgres (docker-compose) ---
POSTGRES_USER=aqb
POSTGRES_PASSWORD=change_me
POSTGRES_DB=aqb

# --- Backend (required from stage 1 onward) ---
# DATABASE_URL password MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgresql+asyncpg://aqb:change_me@localhost:5432/aqb
# JWT signing secret. Generate a real one with:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=replace_me_with_a_random_secret
