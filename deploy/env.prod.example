# Production environment template.
#   1. On the VPS:  cp deploy/env.prod.example deploy/.env.prod
#   2. Fill in the real values below.
#   3. deploy/.env.prod is git-ignored (.env.* rule) — never commit it.
#
# docker-compose.prod.yml injects these into BOTH the postgres and server
# containers. The server reads them straight from the environment
# (settings.py / pydantic-settings); no code change needed for prod.

# --- Postgres (the DB container reads these) ---
POSTGRES_USER=aqb
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
POSTGRES_DB=aqb

# --- Backend ---
# Host MUST be `postgres` — the compose service name on the internal
# network. User/password/db must match the POSTGRES_* values above.
DATABASE_URL=postgresql+asyncpg://aqb:REPLACE_WITH_STRONG_DB_PASSWORD@postgres:5432/aqb

# Strong random secret (NOT the dev one). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=REPLACE_WITH_STRONG_JWT_SECRET

# CORS allow-list. MUST be a JSON array (pydantic-settings parses the
# list[str] field from this env var as JSON). The web frontend origin +
# the Electron desktop shell's fixed custom-scheme origin (stage 4 — the
# desktop app loads the SPA via app://aqb, so it must be allowed here):
CORS_ORIGINS=["https://fastqbank.com","app://aqb"]
# If you also enable the www A-record + Caddy redirect, add:
# CORS_ORIGINS=["https://fastqbank.com","https://www.fastqbank.com","app://aqb"]

# Stage 9 — base URL used to build share-link URLs returned by
# POST /shares. Should match the frontend origin in CORS_ORIGINS.
FRONTEND_BASE_URL=https://fastqbank.com

# --- Stage 6: AI integration (optional) ---
# Leave BOTH blank to run prod WITHOUT AI: every /ai endpoint returns
# 503 and the rest of the site is unaffected. Fill them to enable AI.
# The `ai_usage` table is created automatically (the server container
# runs `alembic upgrade head` on start).
DEEPSEEK_API_KEY=
VISION_API_KEY=
# Optional overrides (sensible defaults — normally leave unset):
# VISION_MODEL=gemini-2.5-flash-lite
# AI_DAILY_TOKEN_LIMIT=200000
# AI_RATE_LIMIT_PER_MIN=20
