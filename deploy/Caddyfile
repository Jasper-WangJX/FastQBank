# Production reverse proxy + static host. Caddy obtains and renews HTTPS
# certificates automatically (Let's Encrypt), provided the domains resolve
# to this server and ports 80/443 are reachable.

# Frontend SPA. try_files falls back to index.html so client-side routes
# (/tags, /questions, ...) work on hard refresh.
fastqbank.com {
	encode gzip zstd

	# Windows installer download. Served from a host-mounted directory
	# (see deploy/docker-compose.prod.yml — `<repo>/downloads/` is
	# bind-mounted to /srv/downloads:ro). `handle_path` strips the
	# /download prefix before file_server resolves, so the file on
	# disk is just `FastQBank-Setup-X.Y.Z.exe`.
	#
	# Both routes are wrapped in `handle` / `handle_path` blocks
	# DELIBERATELY. Without that wrapping, Caddy's directive auto-
	# ordering puts `try_files` (position 9) BEFORE `handle_path`
	# (position 10+), which means try_files rewrites /download/foo.exe
	# → /index.html before the handle_path matcher gets to see the
	# original path — Caddy then serves the SPA shell instead of the
	# .exe. Sibling `handle*` blocks preserve declaration order and
	# only the first matching block runs.
	handle_path /download/* {
		root * /srv/downloads
		file_server
		header Content-Disposition attachment
	}

	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}

# Backend API (separate subdomain — no path collision with SPA routes).
api.fastqbank.com {
	encode gzip zstd
	reverse_proxy server:8000
}

# Optional: enable after adding a `www` A record -> same VPS IP.
