# pnpm 11 re-runs an install/deps check before every `pnpm run`. Because
# Electron's binary-download postinstall is gated (see
# pnpm.onlyBuiltDependencies in package.json), that pre-run check aborts
# the script. The Electron binary is fetched once at install time; skip
# the per-run re-verification so `pnpm dev/start/build` work normally.
verify-deps-before-run=false
