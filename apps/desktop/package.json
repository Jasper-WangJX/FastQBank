{
  "name": "desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Electron desktop shell for FastQBank — reuses the apps/web production build, loaded via a custom app:// protocol.",
  "main": "out/main.js",
  "scripts": {
    "gen:icons": "node scripts/gen-icons.cjs",
    "build:desktop": "tsc -p tsconfig.json",
    "build:web": "cross-env VITE_API_BASE_URL=https://api.fastqbank.com pnpm --dir ../web run build",
    "build:sidecar": "node scripts/build-sidecar.cjs",
    "build": "pnpm build:web && pnpm build:desktop",
    "dev": "cross-env ELECTRON_DEV=1 pnpm build:desktop && cross-env ELECTRON_DEV=1 electron .",
    "start": "electron .",
    "pack": "pnpm build:sidecar && pnpm build && electron-builder --dir",
    "dist": "pnpm build:sidecar && pnpm build && electron-builder"
  },
  "build": {
    "appId": "com.fastqbank.desktop",
    "productName": "FastQBank",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "assets/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web-dist"
      },
      {
        "from": "../../packages/ocr-sidecar/dist/ocr_server",
        "to": "ocr-sidecar"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "shortcutName": "FastQBank",
      "include": "build/installer.nsh"
    }
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8",
    "typescript": "~6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
