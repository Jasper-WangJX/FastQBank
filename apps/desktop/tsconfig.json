{
  "compilerOptions": {
    "target": "es2022",
    // node16 (no "type":"module" in package.json) emits CommonJS, which
    // is what Electron's main process expects, while staying off the
    // deprecated classic "node" resolution.
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,

    /* Mirror apps/web's strictness flags. */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
