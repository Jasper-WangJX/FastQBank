# ============================================================
#  AI-assisted Question Bank — monorepo .gitignore
#  Covers: Node/pnpm (web), Python (server & ocr-sidecar),
#  Electron (later stages), Vite, env secrets, OS & editor.
# ============================================================

# ---------- Node / pnpm ----------
node_modules/
.pnpm-store/
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Build output ----------
dist/
build/
out/
.vite/
*.tsbuildinfo
# Keep the custom NSIS installer include script (source, not build output).
!apps/desktop/build/
!apps/desktop/build/*.nsh

# ---------- Electron packaging (used from stage 4 onward) ----------
dist-electron/
release/

# ---------- Python (apps/server & packages/ocr-sidecar) ----------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------- Secrets / environment ----------
# Never commit real credentials, DB passwords or API keys.
.env
.env.*
!.env.example

# ---------- Databases / local data ----------
*.sqlite
*.sqlite3
*.db
postgres-data/

# ---------- Logs & temp ----------
*.log
logs/
*.tmp
*.bak
coverage/

# ---------- Superpowers (brainstorming visual-companion) ----------
# Transient mockups + session state from the brainstorming skill.
# The design specs under docs/superpowers/ are intentionally tracked.
.superpowers/

# ---------- OS files ----------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

# ---------- Editor / IDE ----------
# Local Claude Code agent config / instructions.
.claude/
CLAUDE.md
.idea/
*.swp
*.swo
# Keep shared VS Code settings, ignore per-user state:
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
